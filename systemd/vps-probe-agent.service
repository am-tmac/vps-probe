[Unit]
Description=Jager Monitor WebSocket Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
ExecStart=/usr/bin/python3 /usr/local/sbin/vps-probe-agent.py
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/etc/vps-probe-agent.json

[Install]
WantedBy=multi-user.target

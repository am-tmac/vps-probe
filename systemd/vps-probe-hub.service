[Unit]
Description=Jager Monitor WebSocket Hub
After=network-online.target vps-probe.service
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/opt/vps-probe
ExecStart=/usr/bin/python3 /opt/vps-probe/ws_hub.py
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=full
MemoryMax=128M
TasksMax=256
LimitNOFILE=1024

[Install]
WantedBy=multi-user.target

# Panel domain: web dashboard and /api/status. The dashboard uses HTTP polling.
panel.example.com {
    encode gzip zstd
    reverse_proxy 127.0.0.1:8088
}

# Agent domain: WebSocket reports only.
agent.example.com {
    encode gzip zstd
    handle /ws {
        reverse_proxy 127.0.0.1:8089
    }
    handle {
        respond "Not Found" 404
    }
}
